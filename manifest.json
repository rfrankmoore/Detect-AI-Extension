{
  "manifest_version": 3,
  "name": "Detect AI",
  "version": "1.0",
  "description": "Detect whether paragraphs on a webpage were written by AI.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Detect AI"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "detectai@mozilla.org",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
