{
  "manifest_version": 3,
  "name": "Detect AI",
  "version": "1.0",
  "description": "Allows option to detect if a webpage section has been generated by AI.",
  "browser_specific_settings": {
    "gecko": {
      "id": "detectai@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*"],
      "js": ["detectai.js"]
    }
  ]
}